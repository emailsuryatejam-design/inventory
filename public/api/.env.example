# WebSquare — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to git — it contains secrets

# ── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ── JWT Authentication ───────────────────────────────
# CRITICAL: Generate a strong secret. Run:
#   openssl rand -hex 64
# The API will REFUSE to start if this is left as default.
JWT_SECRET=generate-a-64-char-hex-secret-here

# ── Google Gemini AI (recipe suggestions) ────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Application ──────────────────────────────────────
APP_URL=https://websquare.pro

# CORS: Only needed for cross-origin requests (mobile app, local dev).
# Same-origin requests (websquare.pro → websquare.pro/api) don't need CORS.
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=capacitor://localhost,http://localhost:5173

# Set to true ONLY for local development. Never in production.
DEBUG=false
